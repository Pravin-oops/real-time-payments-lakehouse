# =============================================================================
# MEDALLION LAKEHOUSE — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS & ENVIRONMENT
# -----------------------------------------------------------------------------
.env
*.key
*.pem
*.p12
*.pfx

# -----------------------------------------------------------------------------
# DELTA LAKE RUNTIME DATA (generated at runtime — never commit)
# -----------------------------------------------------------------------------
delta-lake/bronze/
delta-lake/silver/
delta-lake/gold/
delta-lake/**/checkpoints/
delta-lake/**/_delta_log/

# -----------------------------------------------------------------------------
# RAW DATA LANDING ZONE (generated by producers)
# -----------------------------------------------------------------------------
data/raw/upi/
data/raw/credit_card/

# -----------------------------------------------------------------------------
# AIRFLOW RUNTIME
# -----------------------------------------------------------------------------
airflow/logs/
airflow/plugins/__pycache__/
airflow/dags/__pycache__/

# -----------------------------------------------------------------------------
# SPARK
# -----------------------------------------------------------------------------
spark/jars/
spark/**/__pycache__/
*.jar

# -----------------------------------------------------------------------------
# DBT
# -----------------------------------------------------------------------------
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
.pytest_cache/

# -----------------------------------------------------------------------------
# DOCKER VOLUMES (if mapped locally)
# -----------------------------------------------------------------------------
postgres-data/
pgadmin-data/
zookeeper-data/
kafka-data/

# -----------------------------------------------------------------------------
# OS FILES
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# VS CODE
# -----------------------------------------------------------------------------
.vscode/
*.code-workspace

# -----------------------------------------------------------------------------
# LOGS & TEMP
# -----------------------------------------------------------------------------
*.log
*.tmp
*.swp
*.bak
logs/
tmp/